{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nixclaw.dev/schemas/v1/experiment.schema.json",
  "title": "ExperimentV1",
  "type": "object",
  "required": ["id", "state", "baseGeneration", "workloadId", "hypothesis", "profilePatch", "originalProfileHash", "createdAt", "updatedAt"],
  "properties": {
    "id": { "type": "string", "format": "uuid" },
    "state": { "enum": ["submitted", "validating", "built", "awaitingApproval", "active", "measuring", "accepted", "rejected", "rolledBack", "failed"] },
    "baseGeneration": { "type": "string" },
    "candidateGeneration": { "type": "string" },
    "workloadId": { "type": "string" },
    "hypothesis": { "type": "string" },
    "profilePatch": { "$ref": "vllm-profile-patch.schema.json" },
    "originalProfileHash": { "type": "string" },
    "candidateProfileHash": { "type": "string" },
    "validationFindings": { "type": "array", "items": { "type": "string" } },
    "baselineBenchmark": { "$ref": "benchmark-result.schema.json" },
    "candidateBenchmark": { "$ref": "benchmark-result.schema.json" },
    "decision": { "$ref": "experiment-decision.schema.json" },
    "rollbackReason": { "type": "string" },
    "error": { "type": "string" },
    "createdAt": { "type": "string", "format": "date-time" },
    "updatedAt": { "type": "string", "format": "date-time" }
  },
  "additionalProperties": false
}
