{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nixclaw.dev/schemas/v1/create-experiment-request.schema.json",
  "title": "CreateExperimentRequestV1",
  "type": "object",
  "required": ["baseGeneration", "workloadId", "hypothesis", "profilePatch", "clientRequestId"],
  "properties": {
    "baseGeneration": { "type": "string", "minLength": 1 },
    "workloadId": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,63}$" },
    "hypothesis": { "type": "string", "minLength": 1, "maxLength": 2000 },
    "profilePatch": { "$ref": "vllm-profile-patch.schema.json" },
    "clientRequestId": { "type": "string", "format": "uuid" }
  },
  "additionalProperties": false
}
