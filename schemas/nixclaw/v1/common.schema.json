{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nixclaw.dev/schemas/v1/common.schema.json",
  "$defs": {
    "uuid": { "type": "string", "format": "uuid" },
    "timestamp": { "type": "string", "format": "date-time" },
    "profilePatch": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "gpuMemoryUtilization": { "type": "number", "exclusiveMinimum": 0, "maximum": 1 },
        "maxModelLen": { "type": "integer", "minimum": 1 },
        "maxNumSeqs": { "type": ["integer", "null"], "minimum": 1 },
        "maxNumBatchedTokens": { "type": ["integer", "null"], "minimum": 1 },
        "tensorParallelSize": { "type": "integer", "minimum": 1 },
        "pipelineParallelSize": { "type": "integer", "minimum": 1 },
        "enablePrefixCaching": { "type": "boolean" },
        "enableChunkedPrefill": { "type": ["boolean", "null"] },
        "enforceEager": { "type": "boolean" },
        "kvCacheDtype": {
          "type": ["string", "null"],
          "enum": ["auto", "fp8", "fp8_e4m3", "fp8_e5m2", null]
        }
      },
      "minProperties": 1
    },
    "error": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schemaVersion", "requestId", "error"],
      "properties": {
        "schemaVersion": { "const": "1" },
        "requestId": { "$ref": "#/$defs/uuid" },
        "error": {
          "type": "object",
          "additionalProperties": false,
          "required": ["code", "message", "details"],
          "properties": {
            "code": { "type": "string", "minLength": 1 },
            "message": { "type": "string", "minLength": 1 },
            "details": { "type": "object" }
          }
        }
      }
    }
  }
}
