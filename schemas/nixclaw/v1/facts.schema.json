{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nixclaw.dev/schemas/v1/facts.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "requestId", "data"],
  "properties": {
    "schemaVersion": { "const": "1" },
    "requestId": { "$ref": "common.schema.json#/$defs/uuid" },
    "data": {
      "type": "object",
      "additionalProperties": false,
      "required": ["generation", "nixRevision", "architecture", "gpus", "resources", "cluster", "vllm"],
      "properties": {
        "generation": { "type": "string", "minLength": 1 },
        "nixRevision": { "type": "string", "minLength": 1 },
        "architecture": { "type": "string", "minLength": 1 },
        "gpus": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["index", "model", "computeCapability", "memoryBytes"],
            "properties": {
              "index": { "type": "integer", "minimum": 0 },
              "model": { "type": "string", "minLength": 1 },
              "computeCapability": { "type": "string", "minLength": 1 },
              "memoryBytes": { "type": ["integer", "null"], "minimum": 0 }
            }
          }
        },
        "resources": {
          "type": "object",
          "additionalProperties": false,
          "required": ["cpuCount", "memoryBytes", "swapBytes"],
          "properties": {
            "cpuCount": { "type": "integer", "minimum": 1 },
            "memoryBytes": { "type": "integer", "minimum": 0 },
            "swapBytes": { "type": "integer", "minimum": 0 }
          }
        },
        "cluster": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["nodeId", "role", "rank", "healthy"],
            "properties": {
              "nodeId": { "type": "string", "minLength": 1 },
              "role": { "type": "string", "minLength": 1 },
              "rank": { "type": "integer", "minimum": 0 },
              "healthy": { "type": "boolean" }
            }
          }
        },
        "vllm": {
          "type": "object",
          "additionalProperties": false,
          "required": ["version", "model", "profileHash", "healthy"],
          "properties": {
            "version": { "const": "0.25.1" },
            "model": { "type": "string", "minLength": 1 },
            "profileHash": { "type": "string", "minLength": 1 },
            "healthy": { "type": "boolean" }
          }
        }
      }
    }
  }
}
