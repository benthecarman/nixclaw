{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nixclaw.dev/schemas/v1/reviewed-proposal.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["baseGeneration", "summary", "diff", "clientRequestId"],
  "properties": {
    "baseGeneration": { "type": "string", "minLength": 1 },
    "summary": { "type": "string", "minLength": 1, "maxLength": 1000 },
    "diff": { "type": "string", "minLength": 1, "maxLength": 131072 },
    "clientRequestId": { "$ref": "common.schema.json#/$defs/uuid" }
  }
}
