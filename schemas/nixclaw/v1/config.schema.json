{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nixclaw.dev/schemas/v1/config.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "requestId", "data"],
  "properties": {
    "schemaVersion": { "const": "1" },
    "requestId": { "$ref": "common.schema.json#/$defs/uuid" },
    "data": {
      "type": "object",
      "additionalProperties": false,
      "required": ["baseGeneration", "activeProfileName", "profileHash", "servedModel", "activeProfile", "workloadIds", "tunables"],
      "properties": {
        "baseGeneration": { "type": "string", "minLength": 1 },
        "activeProfileName": { "type": "string", "minLength": 1 },
        "profileHash": { "type": "string", "minLength": 1 },
        "servedModel": { "type": "string", "minLength": 1 },
        "activeProfile": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "gpuMemoryUtilization": { "type": "number", "exclusiveMinimum": 0, "maximum": 1 },
            "maxModelLen": { "type": "integer", "minimum": 1 },
            "maxNumSeqs": { "type": ["integer", "null"], "minimum": 1 },
            "maxNumBatchedTokens": { "type": ["integer", "null"], "minimum": 1 },
            "tensorParallelSize": { "type": "integer", "minimum": 1 },
            "pipelineParallelSize": { "type": "integer", "minimum": 1 },
            "enablePrefixCaching": { "type": "boolean" },
            "enableChunkedPrefill": { "type": ["boolean", "null"] },
            "enforceEager": { "type": "boolean" },
            "kvCacheDtype": { "enum": ["auto", "fp8", "fp8_e4m3", "fp8_e5m2", null] },
            "reasoningParser": { "type": ["string", "null"] },
            "toolCallParser": { "type": ["string", "null"] },
            "speculativeConfig": { "type": ["object", "null"] }
          }
        },
        "workloadIds": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
        "tunables": {
          "type": "object",
          "propertyNames": {
            "enum": [
              "gpuMemoryUtilization",
              "maxModelLen",
              "maxNumSeqs",
              "maxNumBatchedTokens",
              "tensorParallelSize",
              "pipelineParallelSize",
              "enablePrefixCaching",
              "enableChunkedPrefill",
              "enforceEager",
              "kvCacheDtype"
            ]
          },
          "additionalProperties": {
            "type": "object",
            "additionalProperties": false,
            "required": ["type"],
            "properties": {
              "type": { "enum": ["number", "integer", "boolean", "string"] },
              "nullable": { "type": "boolean", "default": false },
              "minimum": { "type": ["number", "null"] },
              "maximum": { "type": ["number", "null"] },
              "step": { "type": ["number", "null"] },
              "values": { "type": ["array", "null"] }
            }
          }
        }
      }
    }
  }
}
