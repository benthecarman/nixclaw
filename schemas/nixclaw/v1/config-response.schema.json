{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nixclaw.dev/schemas/v1/config-response.schema.json",
  "title": "ConfigResponseV1",
  "allOf": [
    { "$ref": "common.schema.json#/$defs/response" },
    { "properties": { "data": {
      "type": "object",
      "required": ["baseGeneration", "activeProfileName", "activeProfileHash", "servedModel", "activeProfile", "workloadIds", "tunableFields", "baselineNodes", "experimentTargets"],
      "properties": {
        "baseGeneration": { "type": "string" }, "activeProfileName": { "type": "string" }, "activeProfileHash": { "type": "string" }, "servedModel": { "type": "string" },
        "activeProfile": { "type": "object" }, "workloadIds": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
        "tunableFields": { "type": "object", "additionalProperties": { "type": "object" } },
        "baselineNodes": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
        "experimentTargets": { "type": "array", "items": { "type": "string" }, "uniqueItems": true }
      }, "additionalProperties": false
    } } }
  ]
}
